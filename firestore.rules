rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DOCUMENTATION
     * 
     * Core Philosophy:
     * This ruleset implements a strict Ownership-based security model for the SecureEntry application. 
     * Access is primarily governed by the user's authentication status and an explicit 'isActive' 
     * flag on their profile, which serves as a central kill-switch for account access.
     * 
     * Data Structure:
     * The database is organized into a flat top-level /users collection. Each document 
     * ID corresponds to the Firebase Authentication UID ({userId}), ensuring a 1:1 
     * mapping between identity and data.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: We rely on the document path (/users/{userId}) to 
     *    enforce ownership, which is the most performant and secure method in Firestore.
     * 2. Status-Based Access: In alignment with the 'SecureEntry' requirement, even the 
     *    owner is denied read/write access if their 'isActive' field is set to false.
     * 3. Denormalization for Authorization: The 'isActive' flag and 'id' are stored 
     *    directly on the User document to allow for atomic, single-document security 
     *    checks without requiring cross-collection lookups.
     * 4. Relational Integrity: On creation, we enforce that the internal 'id' field 
     *    matches the document ID (the Auth UID) to ensure data consistency.
     */

    /**
     * Global Helper Functions
     */

    // Returns true if the request is made by an authenticated user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns true if the authenticated user's UID matches the provided userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Returns true if the document exists and the owner is currently marked as active.
    // This is used to enforce the status-based access control mentioned in the reasoning.
    function isActiveOwner(userId) {
      return isOwner(userId) && resource != null && resource.data.isActive == true;
    }

    /**
     * @description Rules for the User collection. Supports self-registration and owner-only access.
     * @path /users/{userId}
     * @allow (create) if the user is authenticated and the document ID matches their UID.
     * @allow (get, update) if the user is the owner and their account is marked 'isActive'.
     * @deny (list) for any query that doesn't target the user's own document.
     * @principle Path-based ownership combined with attribute-based access control (isActive).
     */
    match /users/{userId} {
      
      // Get and List: Owner can access their own data provided they are active.
      allow get, list: if isOwner(userId) && resource.data.isActive == true;

      // Create: Users can create their own profile. We validate that the internal ID matches the path.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Update: Owner can update their data only if currently active. Prevents changing the primary ID.
      allow update: if isActiveOwner(userId) && request.resource.data.id == resource.data.id;

      // Delete: Explicitly denied. Management of user lifecycle should be handled via the 'isActive' flag.
      allow delete: if false;
    }

  }
}