rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理者かどうかをチェックする関数
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "turibitonemoto@gmail.com" ||
        request.auth.token.email == "admin@hokkai-shinbun.jp" ||
        request.auth.token.email == "editor@hokkai-shinbun.jp" ||
        request.auth.token.email == "admin@example.com"
      );
    }

    // 記事：閲覧は誰でもOK、書き込みは管理者のみ
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ヒーロー画像、広告、設定：閲覧は誰でもOK、書き込みは管理者のみ
    match /hero-images/{heroId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ユーザープロファイル：本人または管理者が読み書き可能
    match /user_profiles/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // お問い合わせ：作成は誰でもOK、閲覧・削除は管理者のみ
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
  }
}
