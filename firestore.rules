rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 基本方針: ログインしている新聞会員であれば、すべてのデータに対して読み書きを許可
    // match /{document=**} はコレクションの一覧表示（list）もカバーします
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 表示用サイト（またはログイン直後）の安定性のために、記事と広告は未ログインでも読めるようにする
    // {articleId=**} とすることで、記事単体(get)と一覧(list)の両方を確実に許可します
    match /articles/{articleId=**} {
      allow read: if true;
    }
    match /ads/{adId=**} {
      allow read: if true;
    }
    
    // システム設定（メンテナンスモード等）も、サイトの状態を確認するために公開
    match /settings/{settingId} {
      allow read: if true;
    }
  }
}