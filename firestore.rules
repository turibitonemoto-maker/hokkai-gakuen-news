rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【重要】このプロジェクトは管理サイトと表示用サイトで共有されています。
    // 管理サイト側からの書き込みを許可するため、開発中は以下のルールを維持してください。
    // 最終的な運用時には適切な認証（Admin権限など）を導入予定です。
    
    // 全パスへのアクセス許可（開発モード）
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 記事コレクション
    match /articles/{articleId} {
      allow read, write: if true;
    }
    
    // ヒーロー画像コレクション
    match /hero-images/{heroId} {
      allow read, write: if true;
    }
    
    // 広告コレクション
    match /ads/{adId} {
      allow read, write: if true;
    }
  }
}