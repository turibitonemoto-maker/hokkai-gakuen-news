rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 開発フェーズおよび管理サイト分離のため、一時的に全コレクションへの認証なしアクセスを許可します
    // 注意: 本番運用時には、特定のIP制限や管理者認証を導入することを強く推奨します
    
    // 全パスへのワイルドカード許可（強制適用のためコメントを更新: 2024-05-20）
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 記事コレクションへの明示的な許可
    match /articles/{articleId} {
      allow read, write: if true;
    }
    
    // ヒーロー画像コレクションへの明示的な許可
    match /hero-images/{heroId} {
      allow read, write: if true;
    }
    
    // 広告コレクションへの明示的な許可
    match /ads/{adId} {
      allow read, write: if true;
    }
  }
}