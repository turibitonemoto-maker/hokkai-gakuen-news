rules_version = '2';

/**
 * FIRESTORE SECURITY RULES: HOKKAI GAKUEN NEWS 1 (ADMIN ONLY)
 * 
 * 運用方針:
 * このシステムは新聞会員専用の管理ツールです。
 * Firebase Authentication で登録された「新聞会員（ログイン済みユーザー）」のみが
 * すべてのコンテンツを読み書きできるように設定します。
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description すべてのドキュメントに対するルール。
     * ログインしている会員であれば、記事、広告、画像、設定、お問い合わせなど
     * すべてのデータの読み取り(get/list)と書き込み(create/update/delete)を許可します。
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * @description 個別のコレクションに対する定義。
     * 上記のグローバルルールでカバーされていますが、構造を明確にするために記述します。
     */
    match /articles/{articleId} {
      allow read, write: if request.auth != null;
    }

    match /ads/{adId} {
      allow read, write: if request.auth != null;
    }

    match /inquiries/{inquiryId} {
      allow read, write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }

    match /hero-images/{imageId} {
      allow read, write: if request.auth != null;
    }
  }
}