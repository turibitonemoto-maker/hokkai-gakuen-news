rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // すべてのデータに対して、ログイン済みなら読み書きOK
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 表示用サイト（将来用）のために、記事と広告だけはログインなしでも読めるようにする
    match /articles/{articleId} {
      allow read: if true;
    }
    match /ads/{adId} {
      allow read: if true;
    }
  }
}