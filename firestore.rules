rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 読み取りは全公開、書き込みは認証済みユーザーのみ
    // このルールにより、権限エラー(Missing or insufficient permissions)を確実に防ぎます。
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 記事、ヒーロー画像、広告などは個別に定義しても良いが、
    // 上記のワイルドカードで既にカバーされています。
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}