rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのコレクションに対して、誰でも読み取り可能にする
    // 書き込み（作成・更新・削除）は認証済みユーザーのみ許可する
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /hero-images/{heroId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // 予備のルール
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}