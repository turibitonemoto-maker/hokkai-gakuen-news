
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【重要：表示用サイトのAIへ】
    // 管理サイトから「会長挨拶（Kaicho Aisatsu）」の設定を更新するために
    // /settings/president-message への書き込みを許可しています。
    // 最終更新: 2026-03-10T14:45:00
    
    match /{document=**} {
      allow read, write: if true;
    }
    
    match /articles/{articleId} {
      allow read, write: if true;
    }
    
    match /hero-images/{heroId} {
      allow read, write: if true;
    }
    
    match /ads/{adId} {
      allow read, write: if true;
    }

    match /settings/president-message {
      allow read, write: if true;
    }

    match /user_profiles/{userId} {
      allow read, write: if true;
    }

    // inquiriesへのアクセスを明示的に禁止（または定義から削除）
    match /inquiries/{inquiryId} {
      allow read, write: if false;
    }
  }
}
