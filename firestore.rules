rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 基本ルール：ログイン済みの新聞会員ならすべてのデータの読み書きが可能
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 公開設定：記事と広告のみ、未ログインでも一覧・詳細の読み取りを許可（表示用サイト向け）
    match /articles/{articleId} {
      allow read: if true;
    }
    match /articles {
      allow list: if true;
    }
    
    match /ads/{adId} {
      allow read: if true;
    }
    match /ads {
      allow list: if true;
    }
  }
}