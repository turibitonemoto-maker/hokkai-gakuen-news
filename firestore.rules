
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 基本方針: ログインしている新聞会員であれば、すべてのデータに対して読み書きを許可
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 表示用サイト（またはログイン直後）の安定性のために、記事、広告、設定は未ログインでも読めるようにする
    // {document=**} を使用して、一覧取得（list）も確実に許可します
    match /articles/{document=**} {
      allow read: if true;
    }
    match /ads/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
    
    // お問い合わせなどはログイン必須の基本方針（match /{document=**}）に従う
  }
}
