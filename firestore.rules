rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 記事データの設定
    match /articles/{articleId} {
      // 閲覧（一覧・詳細）は世界中の誰でもOK
      allow read: if true;
      // 投稿・編集・削除は、Firebase Authでログインしている人だけOK
      allow write: if request.auth != null;
    }
    
    // その他のドキュメント（設定、画像、広告、お問い合わせなど）
    match /{document=**} {
      // 閲覧は誰でもOK（トップページの表示エラーを防ぐ）
      allow read: if true;
      // 書き込みはログインユーザーのみ
      allow write: if request.auth != null;
    }
  }
}