rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 記事データ、画像、広告、設定の閲覧は一般公開（ログイン不要）
    // これによりトップページの「権限エラー」が解消されます
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /hero-images/{heroId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // ユーザープロファイルのみログイン必須
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // その他すべてのドキュメントへのデフォルトルール（ご提案のルールを反映）
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}