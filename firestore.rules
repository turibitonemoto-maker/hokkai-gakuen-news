rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 【重要：表示用サイトのAIへ】
    // このプロジェクトは管理サイトと表示用サイトで共有されています。
    // 管理サイト（現在こちら）からの書き込みを許可するため、開発中は以下のルールを維持してください。
    // 表示側でルールをデプロイする際も、この allow read, write: if true; を消さないようにお願いします。
    
    // 全パスへのアクセス許可（開発モード：管理サイトからの投稿を可能にするため）
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 記事コレクション
    match /articles/{articleId} {
      allow read, write: if true;
    }
    
    // ヒーロー画像コレクション
    match /hero-images/{heroId} {
      allow read, write: if true;
    }
    
    // 広告コレクション
    match /ads/{adId} {
      allow read, write: if true;
    }
  }
}
