rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 管理サイト開発フェーズのため、一時的に全コレクションへの認証なしアクセスを許可します
    // 注意: 本番運用時には、特定の管理者のみが書き込めるようにルールを制限する必要があります
    
    match /{path=**} {
      allow read, write: if true;
    }
    
    // 特定のパスを明示的に指定して、ルールの適用を確実にする
    match /articles/{articleId} {
      allow read, write: if true;
    }
    match /hero-images/{heroId} {
      allow read, write: if true;
    }
    match /ads/{adId} {
      allow read, write: if true;
    }
    match /user_profiles/{userId} {
      allow read, write: if true;
    }
  }
}