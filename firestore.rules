rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのドキュメントに対して
    match /{document=**} {
      // 読み取りは誰でも可能（公式サイトの表示に必要）
      allow read: if true;
      // 書き込み（作成・更新・削除）は特定のメールアドレスを持つ認証済みユーザーのみ許可
      allow write: if request.auth != null && request.auth.token.email == "turibitonemoto@gmail.com";
    }
  }
}