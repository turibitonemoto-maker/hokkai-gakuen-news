rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 読み取りは全公開、書き込みは認証済みユーザーのみ
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 明示的に各コレクションへの権限を定義
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /hero-images/{heroId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}