rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // デプロイ強制用のタイムスタンプ: 2024-05-24T18:50:00Z
    
    // 基本ルール: ログイン済みユーザーは全ドキュメントの読み書きが可能
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 公開データへのパブリックアクセス許可
    match /articles/{articleId} {
      allow read: if true;
    }
    
    match /ads/{adId} {
      allow read: if true;
    }
    
    match /settings/{settingId} {
      allow read: if true;
    }

    match /hero-images/{imageId} {
      allow read: if true;
    }
  }
}