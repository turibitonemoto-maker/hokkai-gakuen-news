rules_version = '2';

/**
 * FIRESTORE SECURITY RULES: HOKKAI GAKUEN NEWS 1 (ADMIN ONLY)
 * 
 * 運用方針:
 * このシステムは新聞会員専用の管理ツールです。
 * ログインしている会員（新聞会員）であれば、すべてのデータの読み書きを許可します。
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description 全てのドキュメントに対するルール。
     * Firebase Authentication で認証されたユーザーであれば、
     * 記事、広告、画像、設定、お問い合わせなど、すべてのデータの読み取りと書き込みを許可します。
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}