rules_version = '2';

/**
 * FIRESTORE SECURITY RULES: HOKKAI GAKUEN NEWS 1 (ADMIN ONLY)
 * 
 * 運用方針:
 * このシステムは新聞会員専用の管理ツールです。
 * ログインしている会員（新聞会員）であれば、すべてのデータの読み書きを許可します。
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description 各コレクションに対する明示的なルール。
     * ログイン済みであれば読み取り（list/get）と書き込みを許可します。
     */
    match /articles/{articleId} {
      allow read, write: if request.auth != null;
    }
    
    match /ads/{adId} {
      allow read, write: if request.auth != null;
    }
    
    match /inquiries/{inquiryId} {
      allow read, write: if request.auth != null;
    }
    
    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }
    
    match /hero-images/{imageId} {
      allow read, write: if request.auth != null;
    }

    /**
     * @description フォールバック用の全域ルール。
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
