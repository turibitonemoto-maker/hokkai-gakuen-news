
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /articles/{articleId} {
      allow read: if true;
    }
    
    match /papers/{paperId} {
      allow read: if true;
    }
    
    match /settings/{settingId} {
      allow read: if true;
    }
  }
}
