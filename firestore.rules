
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 【基本ルール】ログインさえしていれば、メール認証がまだでも全員に全権限を許可（新聞会員専用ツールのため）
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 表示用サイト（またはログイン直後）の安定性のために、記事、広告、設定は未ログインでも読めるようにする
    // {document=**} を使用して、一覧取得（list）も確実に許可します
    match /articles/{document=**} {
      allow read: if true;
    }
    match /ads/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
    
    // お問い合わせやヒーロー画像などは、基本ルール（request.auth != null）に従う
  }
}
