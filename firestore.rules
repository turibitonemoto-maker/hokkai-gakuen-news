rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 読み取りは全公開、書き込みは認証済みユーザーのみ
    // match /{document=**} で全てのコレクション・ドキュメントをカバーします。
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 明示的に記事コレクションへのアクセスを許可（デバッグおよび確実なアクセスのため）
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}