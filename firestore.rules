rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 公開コンテンツ（記事、ヒーロー画像、広告、一般設定）は誰でも読み取り可能
    match /articles/{articleId} { allow read: if true; }
    match /hero-images/{heroId} { allow read: if true; }
    match /ads/{adId} { allow read: if true; }
    match /settings/maintenance { allow read: if true; }
    match /settings/president-message { allow read: if true; }

    // 管理者プロファイルはログイン必須
    match /user_profiles/{userId} { allow read: if request.auth != null; }

    // 書き込みは許可された管理者のみ
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.email == "turibitonemoto@gmail.com" ||
        request.auth.token.email == "admin@hokkai-shinbun.jp" ||
        request.auth.token.email == "editor@hokkai-shinbun.jp" ||
        request.auth.token.email == "hokkaigakuen-news-1@example.com" ||
        request.auth.token.email == "admin@example.com" ||
        request.auth.token.email == "test@test.com" ||
        request.auth.token.email == "user@example.com" ||
        request.auth.token.email == "test@example.com"
      );
    }
  }
}