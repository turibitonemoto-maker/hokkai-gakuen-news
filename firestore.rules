rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 【最強設定】ログインさえしていれば、メール認証の状態や同期ラグを問わず、全ドキュメントへの全権限を許可
    // これにより、ログイン直後のトークン同期タイミングによる 403 (Permission Denied) をバックエンド側で最小化します
    // ルールの再デプロイを強制するためのタイムスタンプ: 2024-05-24T12:05:00Z
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 未ログインユーザー向けの閲覧許可（公式サイト用）
    match /articles/{document=**} {
      allow read: if true;
    }
    match /ads/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
  }
}
