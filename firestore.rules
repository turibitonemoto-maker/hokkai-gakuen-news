rules_version = '2';

/**
 * FIRESTORE SECURITY RULES: SECUREENTRY / HOKKAI GAKUEN NEWS 1
 * 
 * 運用方針:
 * このシステムは新聞会員専用の管理ツールです。
 * Firebase Authentication であなたが登録した会員（ログイン済みユーザー）のみが
 * すべてのコンテンツ（記事、広告、画像、設定、お問い合わせ）を管理できます。
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /**
     * @description ユーザーが認証（ログイン）されているかチェックします。
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description すべてのコレクションに対するルール。
     * 管理専用ツールであるため、ログインしている会員であればすべてのデータの読み書きを許可します。
     * これにより、記事(articles)、広告(ads)、ヒーロー画像(hero-images)、
     * 設定(settings)、お問い合わせ(inquiries) へのアクセスが可能になります。
     */
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description 特定のパスに対する個別設定（将来的な拡張用）。
     * 現在は上記のグルールルールで一括制御していますが、
     * 構造を明確にするために match を記述します。
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /articles/{articleId} {
      allow read, write: if isSignedIn();
    }

    match /ads/{adId} {
      allow read, write: if isSignedIn();
    }

    match /hero-images/{imageId} {
      allow read, write: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /inquiries/{inquiryId} {
      allow read, write: if isSignedIn();
    }
  }
}