
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 全てのコレクションに対して
    match /{document=**} {
      // 読み取り（一覧・詳細）はログインしているユーザーなら誰でも可能
      allow read: if request.auth != null;
      // 書き込み（作成・更新・削除）は特定のメールアドレスを持つ管理者のみ許可
      allow write: if request.auth != null && request.auth.token.email == "turibitonemoto@gmail.com";
    }
  }
}
