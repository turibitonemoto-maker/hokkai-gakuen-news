rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 【最強設定】ログインさえしていれば、全ドキュメントへの全権限を許可
    // 認証同期ラグによる403エラーをバックエンド側で最小化します
    // ルールの再適用を確実にするためのタイムスタンプ: 2024-05-24T14:30:00Z
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 未ログインユーザー向けの閲覧許可（公式サイト用）
    match /articles/{document=**} {
      allow read: if true;
    }
    match /ads/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
  }
}
