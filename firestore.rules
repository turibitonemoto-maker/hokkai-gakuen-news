
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 【基本ルール】ログインさえしていれば、メール認証の状態を問わず全員に全権限を許可
    // これにより、ログイン直後の権限エラーやメール認証によるブロックを回避します
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 表示サイト（またはログイン直後）の安定性のために、記事、広告、設定は未ログインでも読めるようにしておく
    match /articles/{document=**} {
      allow read: if true;
    }
    match /ads/{document=**} {
      allow read: if true;
    }
    match /settings/{document=**} {
      allow read: if true;
    }
  }
}
