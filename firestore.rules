rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 全ドキュメントへの基本権限（ログイン必須）
    // 再適用タイムスタンプ: 2024-05-24T15:00:00Z
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 公開データの閲覧許可（未ログインでもOK）
    // コレクションのリスト（一覧）と各ドキュメントの取得の両方を明示的に許可
    match /articles {
      allow read: if true;
      match /{allPaths=**} {
        allow read: if true;
      }
    }
    
    match /ads {
      allow read: if true;
      match /{allPaths=**} {
        allow read: if true;
      }
    }
    
    match /settings {
      allow read: if true;
      match /{allPaths=**} {
        allow read: if true;
      }
    }
  }
}