{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "学内ニュースやnote連動記事を表すエンティティ。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Ad": {
      "title": "Ad",
      "description": "サイト内に表示するバナー広告。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "clickCount": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "読者からのお問い合わせメッセージ。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "メンテナンスモードや会長挨拶などのシステム設定。",
      "type": "object",
      "properties": {
        "isMaintenanceMode": { "type": "boolean" },
        "maintenanceMessage": { "type": "string" },
        "authorName": { "type": "string" },
        "authorImageUrl": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "記事データの保存場所。"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "広告データの保存場所。"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "お問い合わせデータの保存場所。"
    },
    "/settings/{settingId}": {
      "schema": "SystemSettings",
      "description": "メンテナンスモードや会長挨拶などのシステム設定。"
    },
    "/hero-images/{imageId}": {
      "schema": "object",
      "description": "ヒーロー背景画像のURLリスト。"
    }
  }
}
