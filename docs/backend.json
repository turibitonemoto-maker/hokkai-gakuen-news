
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "ニュース記事および紙面アーカイブデータ。categoryId: 'Viewer' の場合は紙面アーカイブとして扱われます。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "authorName": { "type": "string", "description": "記事の執筆記者名" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "imageCaption": { "type": "string" },
        "categoryId": { "type": "string", "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion", "Viewer"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "pdfUrl": { "type": "string", "format": "uri", "description": "紙面アーカイブのPDFファイルURL" },
        "mainImageTransform": {
          "type": "object",
          "properties": {
            "scale": { "type": "number" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "issueNumber": { "type": "number" },
        "paperImages": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "ニュース記事および紙面アーカイブ（Viewer）の統合データ。"
    },
    "/settings/about": {
      "schema": { "type": "object" },
      "description": "About Us 内容。"
    }
  }
}
