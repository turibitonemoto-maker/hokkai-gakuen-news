
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "学内ニュースやnote連動記事。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Ad": {
      "title": "Ad",
      "description": "バナー広告。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "clickCount": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "記事データ。公開読み取り許可、ログイン者は全権限。"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "広告データ。公開読み取り許可、ログイン者は全権限。"
    },
    "/hero-images/{imageId}": {
      "schema": { "type": "object" },
      "description": "ヒーロー画像。ログイン者のみ全権限。"
    },
    "/settings/{settingId}": {
      "schema": { "type": "object" },
      "description": "システム設定。公開読み取り許可。"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "type": "object" },
      "description": "お問い合わせ。ログイン者のみ閲覧可能。"
    }
  }
}
