
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "記事データ。表示用サイトは isPublished == true のもののみを取得すること。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Ad": {
      "title": "Ad",
      "description": "バナー広告。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "clickCount": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceConfig": {
      "title": "MaintenanceConfig",
      "description": "表示用サイトの制御フラグと伝令メッセージ。",
      "type": "object",
      "properties": {
        "isMaintenanceMode": { "type": "boolean" },
        "maintenanceMessage": { "type": "string" },
        "systemStatusMessage": { "type": "string", "description": "表示サイトへの緊急伝令（例：インデックス作成中）" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "記事データ。"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/backend/entities/Ad" },
      "description": "広告データ。"
    },
    "/settings/maintenance": {
      "schema": { "$ref": "#/backend/entities/MaintenanceConfig" },
      "description": "メンテナンスおよびシステム状況設定。"
    },
    "/settings/president_greeting": {
      "schema": { "type": "object" },
      "description": "会長挨拶。Sacred Scripture: DocID must be 'president_greeting', Field must be 'content'."
    },
    "/settings/note-sync": {
      "schema": { "type": "object" },
      "description": "note同期ログ。"
    }
  }
}
