
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "記事および紙面データ。紙面（Viewer）の場合は mainImageUrl に加え paperImages 配列に全ページのJPEGデータを保持します。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "imageCaption": { "type": "string" },
        "issueNumber": { "type": "number", "description": "第〇号" },
        "categoryId": { "type": "string", "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion", "Viewer"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri", "description": "表紙のJPEG画像データ（Base64）" },
        "mainImageTransform": {
          "type": "object",
          "properties": {
            "scale": { "type": "number" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "paperImages": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "全ページの画像データ配列"
        },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "記事および紙面データ。"
    },
    "/settings/about": {
      "schema": { "type": "object" },
      "description": "About Us 内容。"
    }
  }
}
