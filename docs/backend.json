
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "記事および紙面データ。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard"] },
        "content": { "type": "string" },
        "imageCaption": { "type": "string" },
        "pdfUrl": { "type": "string", "format": "uri", "description": "メインのPDF URL（下位互換用）" },
        "pdfUrls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "例：本紙、別刷、号外" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "issueNumber": { "type": "number", "description": "第〇号" },
        "categoryId": { "type": "string", "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion", "Viewer"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "mainImageTransform": {
          "type": "object",
          "properties": {
            "scale": { "type": "number" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "記事および紙面データ。"
    },
    "/settings/about": {
      "schema": { "type": "object" },
      "description": "About Us 内容。"
    }
  }
}
