
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "新聞の記事データ",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "記事のタイトル" },
        "content": { "type": "string", "description": "記事の本文 (プレーンテキスト)" },
        "categoryId": { 
          "type": "string", 
          "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion"],
          "description": "記事のカテゴリー"
        },
        "publishDate": { "type": "string", "format": "date-time", "description": "公開日" },
        "mainImageUrl": { "type": "string", "description": "メイン画像のURL" },
        "isPublished": { "type": "boolean", "description": "公開フラグ" }
      },
      "required": ["title", "content", "categoryId", "publishDate", "isPublished"]
    },
    "HeroImage": {
      "title": "HeroImage",
      "description": "トップページのヒーロー画像",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Ad": {
      "title": "Ad",
      "description": "広告バナー",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "管理者のプロファイル",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "#/backend/entities/Article",
      "description": "記事一覧"
    },
    "/hero-images/{heroId}": {
      "schema": "#/backend/entities/HeroImage",
      "description": "トップ背景用画像"
    },
    "/ads/{adId}": {
      "schema": "#/backend/entities/Ad",
      "description": "広告バナー"
    },
    "/user_profiles/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "管理者プロファイル"
    }
  }
}
