{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "学内ニュースやnote連動記事を表すエンティティ。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Ad": {
      "title": "Ad",
      "description": "サイト内に表示するバナー広告。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "clickCount": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "HeroImage": {
      "title": "HeroImage",
      "description": "公式サイトのトップ背景画像。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "記事データ。新聞会員のみ編集可能。公開設定されたものは誰でも閲覧可。"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "広告データ。新聞会員のみ編集可能。誰でも閲覧可。"
    },
    "/hero-images/{imageId}": {
      "schema": { "$ref": "#/entities/HeroImage" },
      "description": "ヒーロー画像。新聞会員のみ編集可能。"
    },
    "/settings/{settingId}": {
      "schema": { "type": "object" },
      "description": "システム設定（メンテナンスなど）。新聞会員のみ編集可能。"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "type": "object" },
      "description": "お問い合わせ。新聞会員のみ閲覧・削除可能。"
    }
  }
}