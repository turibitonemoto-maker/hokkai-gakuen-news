
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "記事データ。ログイン済みの新聞会員は全権限。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "noteUrl": { "type": "string", "format": "uri" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Ad": {
      "title": "Ad",
      "description": "バナー広告。ログイン済みの新聞会員は全権限。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "clickCount": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "HeroImage": {
      "title": "HeroImage",
      "description": "ヒーロー背景。ログイン済みの新聞会員は全権限。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "お問い合わせ。ログイン済みの新聞会員は全権限。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "記事全般。ログイン済みのユーザーは全権限。"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "バナー広告。ログイン済みのユーザーは全権限。"
    },
    "/hero-images/{imageId}": {
      "schema": { "$ref": "#/entities/HeroImage" },
      "description": "ヒーロー画像。ログイン済みのユーザーは全権限。"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "お問い合わせ。ログイン済みのユーザーは全権限。"
    },
    "/settings/{settingId}": {
      "schema": { "type": "object" },
      "description": "システム設定。ログイン済みのユーザーは全権限。"
    }
  }
}
