
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "ニュース記事データ。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "articleType": { "type": "string", "enum": ["Standard", "Note"] },
        "content": { "type": "string" },
        "imageCaption": { "type": "string" },
        "categoryId": { "type": "string", "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishDate": { "type": "string", "format": "date" },
        "mainImageUrl": { "type": "string", "format": "uri" },
        "mainImageTransform": {
          "type": "object",
          "properties": {
            "scale": { "type": "number" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "Paper": {
      "title": "Paper",
      "description": "紙面アーカイブデータ。JPEG(Base64)の配列を保持します。",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issueNumber": { "type": "number" },
        "title": { "type": "string" },
        "publishDate": { "type": "string", "format": "date" },
        "paperImages": { "type": "array", "items": { "type": "string" } },
        "mainImageUrl": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["issueNumber", "publishDate", "paperImages"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "ニュース記事データ。"
    },
    "/papers/{paperId}": {
      "schema": { "$ref": "#/backend/entities/Paper" },
      "description": "紙面アーカイブデータ。"
    },
    "/settings/about": {
      "schema": { "type": "object" },
      "description": "About Us 内容。"
    }
  }
}
