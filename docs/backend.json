
{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "新聞の記事データ",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "記事のタイトル" },
        "content": { "type": "string", "description": "記事の本文 (標準記事の場合)" },
        "noteUrl": { "type": "string", "description": "note記事のURL (note連携の場合)" },
        "articleType": { 
          "type": "string", 
          "enum": ["Standard", "Note"],
          "description": "記事のタイプ（標準またはnote連携）"
        },
        "categoryId": { 
          "type": "string", 
          "enum": ["Campus", "Event", "Interview", "Sports", "Column", "Opinion"],
          "description": "記事のカテゴリー"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "検索や分類用のタグ"
        },
        "publishDate": { "type": "string", "format": "date-time", "description": "公開日" },
        "mainImageUrl": { "type": "string", "description": "メイン画像のURL" },
        "isPublished": { "type": "boolean", "description": "公開フラグ" }
      },
      "required": ["title", "articleType", "categoryId", "publishDate", "isPublished"]
    },
    "HeroImage": {
      "title": "HeroImage",
      "description": "トップページのヒーロー画像",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Ad": {
      "title": "Ad",
      "description": "広告バナー",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "title": { "type": "string" },
        "clickCount": { "type": "number", "description": "閲覧数（クリック数）" },
        "startDate": { "type": "string", "format": "date-time", "description": "表示開始日時" },
        "endDate": { "type": "string", "format": "date-time", "description": "表示終了日時" }
      }
    },
    "PresidentMessage": {
      "title": "PresidentMessage",
      "description": "会長の挨拶メッセージ",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "挨拶の本文" },
        "authorName": { "type": "string", "description": "会長の氏名" },
        "authorImageUrl": { "type": "string", "description": "会長の顔写真URL" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "authorName"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "管理者のプロファイル",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": { "$ref": "#/backend/entities/Article" },
      "description": "記事一覧"
    },
    "/hero-images/{heroId}": {
      "schema": { "$ref": "#/backend/entities/HeroImage" },
      "description": "トップ背景用画像"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/backend/entities/Ad" },
      "description": "広告バナー"
    },
    "/settings/president-message": {
      "schema": { "$ref": "#/backend/entities/PresidentMessage" },
      "description": "会長挨拶の設定（ドキュメント）"
    },
    "/user_profiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "管理者プロファイル"
    }
  }
}
